# Source a private copy of this file from the repository root on HPC4.
# These values are paths only; never place credentials or access tokens here.

export PRORM_PROJECT_ROOT="/project/sigroup/smart-reward-model"
export PRORM_SCRATCH_ROOT="/scratch/${USER}/smart-reward-model"

# Asset paths are relative to PRORM_PROJECT_ROOT. Submission scripts resolve
# and validate them before exporting absolute paths to Slurm/Apptainer.
export PRORM_IMAGE="images/prorm.sif"
export PRORM_HF_CACHE="hf-cache"

# Set after the candidate image exists and is hash-frozen. It becomes
# HPC4-validated only after the GPU smoke passes on the chosen partition.
# export PRORM_IMAGE_SHA256="$(sha256sum "${PRORM_PROJECT_ROOT}/${PRORM_IMAGE}" | awk '{print $1}')"

export PRORM_ARRAY_CONCURRENCY=1
